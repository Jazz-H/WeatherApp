# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# Open-Meteo (Phase 1) needs no key.

# Server-only — used by the /api/summarize route in Phase 2.
# This MUST stay server-side and never be exposed with a NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=

# Optional safety cap: max Claude calls per day (per warm instance). Bounds cost.
# Defaults to 500 if unset.
MAX_AI_CALLS_PER_DAY=500
